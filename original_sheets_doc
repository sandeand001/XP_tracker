    // Coins Earned Today (sum positive gains for today in XP Log — Date stored as text yyyy-mm-dd)
    sh.getRange(row, 2).setFormula(
      `=IF(LEN(${nameRef})=0,"",IFERROR(SUMIFS('XP Log'!$G:$G,'XP Log'!$B:$B,${nameRef},'XP Log'!$A:$A,TEXT(${today},"yyyy-mm-dd"),'XP Log'!$G:$G,">0"),0))`
    );
    // Total Earned (sum positive gains)
    sh.getRange(row, 3).setFormula(
      `=IF(LEN(${nameRef})=0,"",IFERROR(SUMIFS('XP Log'!$G:$G,'XP Log'!$B:$B,${nameRef},'XP Log'!$G:$G,">0"),0))`
    );
    // Total Spent (sum negative gains, shown positive)
    sh.getRange(row, 4).setFormula(
      `=IF(LEN(${nameRef})=0,"",-IFERROR(SUMIFS('XP Log'!$G:$G,'XP Log'!$B:$B,${nameRef},'XP Log'!$G:$G,"<0"),0))`
    );
    // Spend Now is user input; clear validation and set numeric rule
    try {
      const rg = sh.getRange(row, 5);
      rg.clearDataValidations();
      const rule = SpreadsheetApp.newDataValidation().requireNumberGreaterThanOrEqualTo(1).setAllowInvalid(false).build();
      rg.setDataValidation(rule).setNote('Enter coins to spend; posting will deduct and clear this cell.');
    } catch (e) {}
    // Current Balance = Earned - Spent
    sh.getRange(row, 6).setFormula(`=IF(LEN(${nameRef})=0,"", C${row}-D${row})`);
  }
  // Banding
  try {
    (sh.getBandings()||[]).forEach(b=>b.remove());
    const rng = sh.getRange(1,1,26,6);
    const band = rng.applyRowBanding(SpreadsheetApp.BandingTheme.LIGHT_GREY);
    band.setHeaderRowColor('#EDE8D9');
    band.setFirstRowColor('#FFFFFF');
    band.setSecondRowColor('#F7F5ED');
  } catch (e) {}
  return sh;
}

