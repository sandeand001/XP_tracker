      const lv = (legacyL[i][0] || '').toString().trim();
      const kv = (legacyK[i][0] || '').toString().trim();
      const pick = allowed.has(lv) ? lv : (allowed.has(kv) ? kv : '');
      if (pick) { curJ[i][0] = pick; changed = true; }
    }
    if (changed) tracker.getRange(2, 10, 25, 1).setValues(curJ);
  } catch (e) {}

  // Guilds now in J2:J1000
  try { tracker.getRange("J2:J1000").clearDataValidations(); } catch (e) {}
