/*** RECOMPUTE PROGRESS ********************************************************
 * Recalculates level-related derived fields (Title, CumXP already stored, Level,
 * XP in Level, XP To Next, Sparkline formula, Progress %) for every student on
 * the XP Tracker using current level thresholds & prestige titles. Useful after
 * adjusting level thresholds or manually editing cumulative XP.
 */
function recomputeAllLevelsAndProgress() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const tracker = ss.getSheetByName('XP Tracker');
  if (!tracker) { SpreadsheetApp.getActive().toast('XP Tracker sheet missing'); return; }

  const lastRow = tracker.getLastRow();
  if (lastRow < 2) { SpreadsheetApp.getActive().toast('No student rows to recompute'); return; }

  // Columns layout expectation (A:Name, B:Title, C:CumXP, D:Level, E:XPInLevel, F:XPToNext, G:Sparkline, H:Progress, I:Debt, J:Guild)
  const num = lastRow - 1;
  const names = tracker.getRange(2,1,num,1).getValues().map(r => (r[0]||'').toString().trim());
  const cumXPs = tracker.getRange(2,3,num,1).getValues().map(r => Number(r[0])||0);

  const out = Array.from({length:num}, () => new Array(8).fill('')); // B..I (skip A & J)

  for (let i=0;i<num;i++) {
    const name = names[i];
    if (!name) continue; // leave blank row
    const cumXP = cumXPs[i];
    const level = getLevelFromXP(cumXP);
    const baseXP = levelThresholds[level-1];
    const currentLevelXP = cumXP - baseXP;
    const xpToNext = getXPForLevel(level); // returns 0 at max level
    const xpToNextDisplay = xpToNext === 0 ? 0 : Math.max(0, xpToNext - currentLevelXP);
    const percentProgress = xpToNext === 0 ? 1 : (currentLevelXP / xpToNext);
    const title = determineTitle(cumXP, level);
    const rowNum = i + 2;
    out[i][0] = title; // B
    out[i][1] = cumXP; // C (reaffirm)
    out[i][2] = level; // D
    out[i][3] = currentLevelXP; // E
    out[i][4] = xpToNextDisplay; // F
    out[i][5] = `=SPARKLINE(H${rowNum}, {"charttype","bar";"max",1;"color1","green"})`; // G
    out[i][6] = percentProgress; // H
    // Debt left untouched (I) – keep existing value
    const debt = tracker.getRange(rowNum,9).getValue();
    out[i][7] = debt; // I
  }

  // Write back B..I
  tracker.getRange(2,2,num,8).setValues(out);

  // Trigger leaderboard rebuild regardless of signature (force by clearing stored sig)
  try { PropertiesService.getDocumentProperties().deleteProperty('LB_SIG'); } catch (e) {}
  updateLeaderboard();
  SpreadsheetApp.getActive().toast('Progress recomputed for '+num+' rows.');
}

