function protectNameColumns_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheets = ["Daily Checklist", "Behavior Tracker"]
    .map(n => ss.getSheetByName(n))
    .filter(sh => !!sh);
  const desc = 'LOCK: Name column mirrors XP Tracker';
  sheets.forEach(sh => {
    try {
      (sh.getProtections(SpreadsheetApp.ProtectionType.RANGE) || [])
        .filter(p => {
          try { return p.getDescription && p.getDescription() === desc; } catch (e) { return false; }
        })
        .forEach(p => p.remove());
    } catch (e) {}

    const lastRow = Math.max(26, sh.getMaxRows());
    if (lastRow <= 1) return;
    const rg = sh.getRange(2, 1, lastRow - 1, 1); // A2:A
    const prot = rg.protect().setDescription(desc);
    try {
      const editors = prot.getEditors();
      if (editors && editors.length) prot.removeEditors(editors);
      if (prot.canDomainEdit()) prot.setDomainEdit(false);
      prot.setWarningOnly(false);
    } catch (e) {}
  });
}

