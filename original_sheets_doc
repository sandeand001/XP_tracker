// Date at midnight (sheet TZ) for reliable equality with TODAY()
function todayDateOnly_() {
  try {
    const now = new Date();
    const tz = TZ || SpreadsheetApp.getActive().getSpreadsheetTimeZone();
    const y = Number(Utilities.formatDate(now, tz, 'yyyy'));
    const m = Number(Utilities.formatDate(now, tz, 'MM'));
    const d = Number(Utilities.formatDate(now, tz, 'dd'));
    return new Date(y, m - 1, d, 0, 0, 0, 0);
  } catch (e) {
    // Fallback: strip time in local
    const t = new Date(); return new Date(t.getFullYear(), t.getMonth(), t.getDate());
  }
}

