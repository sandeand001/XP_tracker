    {h:'🎉 You\'re Ready', lines:[
      'Keep it simple at first—mark a few items.',
      'Process Daily XP. Show progress. Celebrate.',
      'Expand gradually. Have fun with it!'
    ]}
  ];

  let row = 4;
  SECTIONS.forEach((sec, idx) => {
    const color = pastel[idx % pastel.length];
    const header = sh.getRange(row,1,1,9).merge();
    header.setValue(sec.h)
      .setFontWeight('bold').setFontSize(18)
      .setBackground(color).setFontColor(headerText)
      .setHorizontalAlignment('left').setVerticalAlignment('middle')
      .setWrap(true);
    sh.setRowHeight(row, 34);
    row++;
    sec.lines.forEach(line => {
      const r = sh.getRange(row,1,1,9).merge();
      r.setValue('• '+line)
        .setFontSize(12)
        .setFontFamily('Arial')
        .setBackground('#FFFFFF')
        .setFontColor(bodyText)
        .setWrap(true);
      sh.setRowHeight(row, 24);
      row++;
    });
    row++; // spacer
  });

  const footerRow = row + 1;
  sh.getRange(footerRow,1,1,9).merge().setValue('Made for teachers — minimal clicks, maximum encouragement ✨')
    .setHorizontalAlignment('center').setFontStyle('italic')
    .setFontColor('#546E7A').setBackground('#E0F2F1');
  sh.activate();
}

