  try { nameRg.setRichTextValues(colNameRt); } catch (e) { nameRg.setValues(colNameRt.map(rt => [rt[0].getText ? rt[0].getText() : ""])); }
  nameRg.setFontSize(nameFont);
  lb.getRange(ROW_START, 3, dataRowsAll, 1).setValues(colTitle).setFontSize(titleFont).setWrapStrategy(SpreadsheetApp.WrapStrategy.WRAP);
  lb.getRange(ROW_START, 4, dataRowsAll, 1).setValues(colLevel).setHorizontalAlignment("center").setFontSize(titleFont);

  rows.forEach((r, i) => {
