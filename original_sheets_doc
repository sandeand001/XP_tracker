function drawBarsWithSpacers_(lb, firstDataRow, colStart, segments, progresses, colorFill, colorEmpty, barRowHeight, spacerRowHeight) {
  const num = progresses.length;
  if (num === 0) return;
  const totalRows = num * 2; // data + spacer rows
  const block = lb.getRange(firstDataRow, colStart, totalRows, segments);
  // Build background matrix for entire block
  const bgs = Array.from({ length: totalRows }, (_, r) => {
    if (r % 2 === 1) return Array(segments).fill(colorEmpty); // spacer row
    const idx = Math.floor(r / 2);
    const p = Math.max(0, Math.min(1, Number(progresses[idx]) || 0));
    const filled = Math.round(p * segments);
    return Array.from({ length: segments }, (_, c) => c < filled ? colorFill : colorEmpty);
  });
  try { block.clearContent(); } catch (e) {}
  block.setBackgrounds(bgs).setBorder(false, false, false, false, false, false);
  // Set row heights in two quick passes
  for (let i = 0; i < num; i++) {
    const row = firstDataRow + i * 2;
    const spacer = row + 1;
    lb.setRowHeight(row, barRowHeight);
    lb.setRowHeight(spacer, spacerRowHeight);
  }
}

function updateLeaderboard() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const tracker = ss.getSheetByName("XP Tracker");
  if (!tracker) throw new Error("XP Tracker sheet not found.");

  // --- Compute signature FIRST (from tracker only). If unchanged, bail early. ---
  const lastRow = tracker.getLastRow();
  const n = Math.max(0, lastRow - 1);

  const names    = n ? tracker.getRange(2, 1, n, 1).getValues().map(r => (r[0]||"").toString().trim()) : [];
  const titles   = n ? tracker.getRange(2, 2, n, 1).getValues().map(r => (r[0]||"").toString().trim()) : [];
  const cumXPs   = n ? tracker.getRange(2, 3, n, 1).getValues().map(r => Number(r[0])||0) : [];
  const levels   = n ? tracker.getRange(2, 4, n, 1).getValues().map(r => Number(r[0])||0) : [];
  const progress = n ? tracker.getRange(2, 8, n, 1).getValues().map(r => {
                      const v = Number(r[0]); return isFinite(v) ? Math.max(0, Math.min(1, v)) : 0;
                    }) : [];
  // Guilds now live in column J (10)
  const guildVals = n ? tracker.getRange(2, 10, n, 1).getValues().map(r => (r[0]||"").toString().trim()) : [];

  // Include participation streaks in signature so badge changes trigger rebuilds
  const streaks = computeParticipationStreaks_();

  const sigParts = [];
  for (let i = 0; i < n; i++) {
    if (!names[i]) continue;
    const streakCount = (streaks[names[i]] && streaks[names[i]].count) || 0;
    sigParts.push(names[i], String(cumXPs[i]||0), String(levels[i]||0), String(progress[i]||0), guildVals[i]||"", String(streakCount));
  }
  const sig = Utilities.base64EncodeWebSafe(
    Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, sigParts.join('|'))
      .map(function(c){return String.fromCharCode(c)}).join('')
  );
  const props = PropertiesService.getDocumentProperties();
  const prevSig = props.getProperty('LB_SIG');
  if (prevSig && prevSig === sig) {
    // No changes; skip costly rebuild
    return;
  }

  // --- Only now touch the Leaderboard sheet ---
  const SHEET_NAME = "Leaderboard";
  let lb = ss.getSheetByName(SHEET_NAME);
  if (!lb) lb = ss.insertSheet(SHEET_NAME);

  lb.clear({ contentsOnly: false });
  breakAllMerges_(lb);
  lb.setFrozenRows(0);
  lb.setFrozenColumns(0);
  lb.setHiddenGridlines(true);

  const BAR_SEGMENTS   = 36;
  const ROW_START      = 4;   // first data row (row 2 guild summary, row 3 headers)
  const NUM_ROWS       = 25;  // entries
  const ROW_STEP       = 2;   // spacer between rows
  const BAR_START_COL  = 6;   // F
  const LEFT_BRACE_COL = BAR_START_COL - 1;
  const RIGHT_BRACE_COL= BAR_START_COL + BAR_SEGMENTS;
  const NEXT_XP_COL    = RIGHT_BRACE_COL + 1; // new: XP to next
  const TOTAL_XP_COL   = RIGHT_BRACE_COL + 2;
  const TOTAL_COLS     = TOTAL_XP_COL;

  const PARCHMENT  = "#FBF7E9";
  const INK        = "#3D2B1F";
  const BAR_FILL   = "#6E4AB1";
  const BAR_EMPTY  = "#F3EFE3";

  setupLeaderboardFrameNoPct_(lb, "Student Leaderboard", FANTASY_FONT, NAME_FONT_FALLBACK, null, null, BAR_SEGMENTS, BAR_START_COL);

  // Map name -> guild for accurate coloring after sorting
  const guildByName = {};
  for (let i = 0; i < n; i++) {
    const nm = names[i];
    if (nm) guildByName[nm] = guildVals[i] || "";
  }
  const guildColorByLabel = GUILDS.reduce((m,g)=>{ m[g.label]=g.bg; return m; }, {});

  // Guild summary: prefer latest per-day totals (if present) stored by processDailyXP; fall back to cumulative sums
  const guildStats = new Map();
  let persistedDaily = null;
  try {
    const props = PropertiesService.getDocumentProperties();
    const raw = props.getProperty('LATEST_GUILD_DAILY_XP');
    if (raw) persistedDaily = JSON.parse(raw);
  } catch (e) { persistedDaily = null; }

  // If stored payload includes a date, ensure it's today's date; otherwise ignore to avoid stale displays
  const todayStr = Utilities.formatDate(new Date(), TZ, "yyyy-MM-dd");
  if (persistedDaily && persistedDaily.date && persistedDaily.totals) {
    if (persistedDaily.date !== todayStr) persistedDaily = null;
    else persistedDaily = persistedDaily.totals;
  }

  if (persistedDaily && Object.keys(persistedDaily).length) {
    // Use persisted per-guild XP totals only if there are actually members in the tracker
    for (let i = 0; i < n; i++) {
      const nm = names[i];
      const g  = guildVals[i];
      if (!nm || !g) continue;
      const entry = guildStats.get(g) || { members: 0, xp: 0 };
      entry.members += 1; guildStats.set(g, entry);
    }
    // If no members found in tracker, ignore persistedDaily as it is stale
    const totalMembers = Array.from(guildStats.values()).reduce((s, v) => s + (v.members || 0), 0);
    if (totalMembers === 0) {
      // fall back to cumulative behavior below
      persistedDaily = null;
    } else {
      Object.keys(persistedDaily).forEach(k => {
        const entry = guildStats.get(k) || { members: 0, xp: 0 };
        entry.xp = Number(persistedDaily[k]) || 0;
        guildStats.set(k, entry);
      });
    }
  }

  if (!persistedDaily || Object.keys(persistedDaily).length === 0) {
    // Fallback to previous behavior: sum cumulative XP per guild
    for (let i = 0; i < n; i++) {
      const nm = names[i];
      const g  = guildVals[i];
      if (!nm || !g) continue;
      const cum = Number(cumXPs[i]) || 0;
      const entry = guildStats.get(g) || { members: 0, xp: 0 };
      entry.members += 1; entry.xp += cum; guildStats.set(g, entry);
    }
  }

  if (guildStats.size) {
    const rg = lb.getRange(2, 2, 1, TOTAL_COLS - 1);
    try { rg.merge(); } catch (e) {}
    const topLeft = rg.getCell(1,1);
    rg.setFontColor(INK);
    const parts = [];
    const seen = new Set();
    GUILDS.forEach(g => { if (guildStats.has(g.label)) { parts.push({label:g.label, color:g.bg, data:guildStats.get(g.label)}); seen.add(g.label);} });
    guildStats.forEach((v,k)=>{ if(!seen.has(k)) parts.push({label:k, color:guildColorByLabel[k] || null, data:v}); });
    let text = '';
    const spans = [];
    parts.forEach((p, idx) => {
      const sep = idx === 0 ? '' : '   |   ';
      const bullet = '● ';
      const segment = `${sep}${bullet}${p.label}: ${p.data.xp.toLocaleString()} XP`;
      const start = text.length + sep.length;
      text += segment;
      const labelStart = start + bullet.length;
      spans.push({ s: labelStart, e: labelStart + p.label.length, color: p.color, bold: true });
    });
    const builder = SpreadsheetApp.newRichTextValue().setText(text);
    spans.forEach(sp => {
      const style = SpreadsheetApp.newTextStyle().setBold(sp.bold);
      if (sp.color) style.setForegroundColor(sp.color);
      builder.setTextStyle(sp.s, sp.e, style.build());
    });
    topLeft.setRichTextValue(builder.build());
    rg.setHorizontalAlignment('center')
      .setFontFamily(FANTASY_FONT + ", " + NAME_FONT_FALLBACK)
      .setFontSize(isCompactModeEnabled_() ? 10 : 12)
      .setFontStyle('italic');
  }

  const populated = [];
  for (let i = 0; i < n; i++) {
    if (!names[i]) continue;
    const title = titles[i] || determineTitle(cumXPs[i], levels[i]);
    populated.push({ name: names[i], title, level: levels[i], cumXP: cumXPs[i], progress: progress[i] });
  }
  populated.sort((a,b) => (b.level - a.level) || (b.cumXP - a.cumXP));

  let rank = 0, pos = 0, prevL = null, prevXP = null;
  for (const r of populated) {
    pos++;
    if (r.level !== prevL || r.cumXP !== prevXP) { rank = pos; prevL = r.level; prevXP = r.cumXP; }
    r.rank = rank;
  }

  const rows = populated.slice(0, NUM_ROWS);
