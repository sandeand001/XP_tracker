// Spend coins from a student with balance validation
function spendCoins(student, amount, note) {
  const name = (student || '').toString().trim();
  const amt = Math.floor(Number(amount) || 0);
  if (!name) throw new Error('Student is required.');
  if (!isFinite(amt) || amt <= 0) throw new Error('Amount must be a positive integer.');
  const balance = getCoinBalance(name);
  if (balance < amt) throw new Error(`Insufficient coins. Balance: ${balance}, required: ${amt}`);
  const dateOnly = todayDateOnly_();
  appendSpendToXPLog_(dateOnly, name, amt, (note || 'Shop spend'));
  return getCoinBalance(name);
}

