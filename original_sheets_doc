// Compute recent contiguous participation streak per student (ignores unlogged days)
function computeParticipationStreaks_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const log = ss.getSheetByName('XP Log');
  const out = {};
  if (!log) return out;
  const lastRow = log.getLastRow();
  if (lastRow < 2) return out;
  // Only read the columns we need: A (Date), B (Student), AB (ParticipationCount=28)
  const dateVals = log.getRange(2, 1, lastRow - 1, 1).getValues();
  const nameVals = log.getRange(2, 2, lastRow - 1, 1).getValues();
  const partVals = log.getRange(2, 28, lastRow - 1, 1).getValues();
  // Build map: name -> (date -> latest partCount for that date). This dedupes multiple runs in same day.
  const byNameDate = new Map();
  for (let i = 0; i < lastRow - 1; i++) {
    const dateStr = (dateVals[i][0] || '').toString();
    const name = (nameVals[i][0] || '').toString();
    if (!name || !dateStr) continue;
    const partCount = Number(partVals[i][0]) || 0;
    let dateMap = byNameDate.get(name);
    if (!dateMap) { dateMap = new Map(); byNameDate.set(name, dateMap); }
    // Later rows overwrite earlier ones, so we keep the last seen value for the date
    dateMap.set(dateStr, partCount);
  }
  const badgeFor = (n) => {
    if (n >= 20) return '🏆';
    if (n >= 15) return '💎';
    if (n >= 10) return '💥';
    if (n >= 5)  return '🔥';
    return '';
  };
  // For each name, sort unique dates desc and count contiguous qualifying days from most recent
  byNameDate.forEach((dateMap, name) => {
    const arr = Array.from(dateMap.entries()).map(([d, p]) => ({ d, p }));
    arr.sort((a,b) => a.d < b.d ? 1 : (a.d > b.d ? -1 : 0));
    let streak = 0;
    for (const it of arr) {
      if ((Number(it.p) || 0) >= 3) streak++; else break;
    }
    out[name] = { count: streak, badge: badgeFor(streak) };
  });
  return out;
}

