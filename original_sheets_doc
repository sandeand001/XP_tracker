// Build an audit sheet comparing expected coins (floor(total XP / rate)) vs actual minted/spent per student
function currencyAudit() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  try { enforceExchangeRate20_(); } catch (e) {}
  const rate = Math.max(1, Number(getRuntimeConfig_().EXCHANGE_RATE) || 20);
  const log = ss.getSheetByName('XP Log');
  if (!log) { try { ss.toast('XP Log not found.', 'Currency Audit', 3); } catch (e) {} return; }
  const lastRow = log.getLastRow();
  const n = Math.max(0, lastRow - 1);
  const names = n ? log.getRange(2, 2, n, 1).getValues().map(r => (r[0]||'').toString().trim()) : [];
  const xp    = n ? log.getRange(2, 5, n, 1).getValues().map(r => Number(r[0])||0) : []; // E XPToLevel
  const coins = n ? log.getRange(2, 7, n, 1).getValues().map(r => Number(r[0])||0) : [];
  const by = new Map();
  for (let i = 0; i < n; i++) {
    const nm = names[i]; if (!nm) continue;
    let rec = by.get(nm); if (!rec) { rec = { totalXP:0, earned:0, spent:0 }; by.set(nm, rec); }
    rec.totalXP += xp[i] || 0;
    const c = coins[i] || 0;
    if (c > 0) rec.earned += c; else if (c < 0) rec.spent += -c;
  }
  const rows = Array.from(by.entries()).map(([nm, r]) => {
    const expected = Math.floor((r.totalXP || 0) / rate);
    const actual = r.earned || 0;
    const diff = actual - expected;
    const balance = (r.earned || 0) - (r.spent || 0);
    return [nm, r.totalXP, expected, actual, r.spent, balance, diff];
  });
  let sh = ss.getSheetByName('Currency Audit');
  if (!sh) sh = ss.insertSheet('Currency Audit');
  sh.clear();
  sh.getRange(1,1,1,7).setValues([[
    'Name','Total Applied XP (E)','Expected Coins (floor(XP/rate))','Actual Coins Earned','Total Spent','Current Balance','Discrepancy (Actual-Expected)'
  ]]).setFontWeight('bold');
  if (rows.length) sh.getRange(2,1,rows.length,7).setValues(rows);
  try {
    sh.getRange(1,1,Math.max(2,rows.length+1),7).createFilter();
    sh.autoResizeColumns(1,7);
  } catch (e) {}
  try { ss.toast('Currency Audit updated.', 'Currency Audit', 4); } catch (e) {}
  try { SpreadsheetApp.setActiveSheet(sh); } catch (e) {}
}


