  const testTerm = `IFERROR(VLOOKUP(B${row}, 'XP Config'!$A$2:$B$6, 2, FALSE), 0)`;
  const formula =
    `${testTerm}+` +
    `IF(C${row},${w.quiz},0)+IF(D${row},${w.faculty},0)+` +
    `IF(E${row},${w.exitTicket},0)+IF(F${row},${w.writing},0)+IF(G${row},${w.kindness},0)+` +
    `IF(H${row},${w.expectations},0)+` +
    `IF(I${row},${w.participationEach},0)+IF(J${row},${w.participationEach},0)+` +
    `IF(K${row},${w.participationEach},0)+IF(L${row},${w.participationEach},0)+` +
    `IF(M${row},${w.participationEach},0)+` +
    `IF(N${row}=TRUE,VALUE($N$1),0)+IF(O${row}=TRUE,VALUE($O$1),0)+` +
    `IF(P${row}=TRUE,VALUE($P$1),0)+IF(Q${row}=TRUE,VALUE($Q$1),0)`;
  daily.getRange(`R${row}`).setFormula(formula);
}

