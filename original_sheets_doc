function setCommentsMatrixValue_(sheetName, dateStr, student, dailyComment, behaviorComment) {
  const s = ensureCommentsMatrixSheet_(sheetName);
  const row = getOrCreateDateRowIndex_(s, dateStr);
  const col = getOrCreateStudentColIndex_(s, student);
  const d = (dailyComment || "").toString().trim();
  const b = (behaviorComment || "").toString().trim();

  if (!d && !b) { s.getRange(row, col).setValue(""); return; }

  let text = "", ranges = [];
  if (d) { text += d; ranges.push({start:0, end:d.length, color:null}); }
  if (b) {
    if (text.length) text += "\n";
    const start = text.length; text += b;
    ranges.push({start, end:start + b.length, color:"#b71c1c"});
  }

  const builder = SpreadsheetApp.newRichTextValue().setText(text);
  ranges.forEach(r => {
    const style = SpreadsheetApp.newTextStyle();
    if (r.color) builder.setTextStyle(r.start, r.end, style.setForegroundColor(r.color).build());
    else builder.setTextStyle(r.start, r.end, style.build());
  });
  const cell = s.getRange(row, col);
  cell.setRichTextValue(builder.build());
  cell.setWrapStrategy(SpreadsheetApp.WrapStrategy.WRAP);
}
function ensureCommentsMatrixSheet_(name) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let s = ss.getSheetByName(name);
  if (!s) {
    s = ss.insertSheet(name);
    let names = [];
    try {
      const first = ss.getSheets()[0];
      if (first) {
        const lastRow = first.getLastRow();
        const n = Math.max(0, lastRow - 1);
        if (n > 0) names = first.getRange(2, 1, n, 1).getValues().map(r => (r[0] || "").toString()).filter(x => x);
      }
    } catch (e) {}
    if (names.length === 0) {
      const tracker = ss.getSheetByName("XP Tracker");
      const lastRow = tracker ? tracker.getLastRow() : 1;
      const n = Math.max(0, lastRow - 1);
      if (n > 0) names = tracker.getRange(2, 1, n, 1).getValues().map(r => (r[0] || "").toString()).filter(x => x);
    }
    s.appendRow(["Date"].concat(names));
  }
  if (s.getLastRow() === 0) s.appendRow(["Date"]);
  // Ensure column A (Date) uses a consistent display format
  try { s.getRange("A:A").setNumberFormat("yyyy-mm-dd"); } catch (e) {}
  return s;
}
function getOrCreateDateRowIndex_(sheet, dateStr) {
  const lastRow = sheet.getLastRow();
  if (lastRow < 1) {
    sheet.appendRow(["Date"]);
  }
  const nRows = sheet.getLastRow();
  const vals = nRows > 1 ? sheet.getRange(2, 1, nRows - 1, 1).getValues() : [];
  const normalize = (v) => {
    if (v instanceof Date) {
      return Utilities.formatDate(v, TZ, "yyyy-MM-dd");
    }
    const s = (v || "").toString().trim();
    if (!s) return "";
    // If already yyyy-mm-dd, keep it
    if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
    const d = new Date(s);
    if (!isNaN(d.getTime())) return Utilities.formatDate(d, TZ, "yyyy-MM-dd");
    return s;
  };
  const matches = [];
  for (let i = 0; i < vals.length; i++) {
    const norm = normalize(vals[i][0]);
    if (norm === dateStr) matches.push(2 + i); // row index
  }
  if (matches.length === 0) {
    sheet.appendRow([dateStr]);
    return sheet.getLastRow();
  }
  // Deduplicate: keep first occurrence; delete later ones bottom-up
  const keep = matches[0];
  for (let k = matches.length - 1; k >= 1; k--) {
    try { sheet.deleteRow(matches[k]); } catch (e) {}
  }
  return keep;
}
function getOrCreateStudentColIndex_(sheet, student) {
  const lastCol = sheet.getLastColumn();
  const header = sheet.getRange(1,1,1,lastCol).getValues()[0];
  let j = header.findIndex((v, i) => i>0 && (v || "").toString() === student);
  if (j !== -1) return j + 1;
  sheet.getRange(1, lastCol + 1).setValue(student);
  return lastCol + 1;
}

