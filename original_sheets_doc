// Upsert: for a given date string (yyyy-MM-dd), ensure only one row per (date, student) exists.
// If there are existing rows for that date/student, they are deleted first, then new rows are appended in batch.
function upsertXPLogRowsForDate_(dateStr, rows) {
  const s = ensureXPLogSheet_();
  const colCount = 38;
  if (!rows || !rows.length) return;
  const lastRow = s.getLastRow();
  if (lastRow >= 2) {
    const dates = s.getRange(2, 1, lastRow - 1, 1).getValues(); // A
    const names = s.getRange(2, 2, lastRow - 1, 1).getValues(); // B
    // Build set of student names to be upserted (from incoming rows)
    const upsertNames = new Set(rows.map(r => (r[1] || "").toString()));
    // Collect row indices to delete (1-based absolute rows in sheet)
    const toDelete = [];
    for (let i = 0; i < lastRow - 1; i++) {
      const d = (dates[i][0] || "").toString();
      if (d !== dateStr) continue;
      const n = (names[i][0] || "").toString();
      if (upsertNames.has(n)) toDelete.push(i + 2);
    }
    // Delete from bottom to top to preserve indices
    if (toDelete.length) {
      toDelete.sort((a,b)=>b-a).forEach(r => { try { s.deleteRow(r); } catch (e) {} });
    }
  }
  // Append the new data (normalized width)
  const data = rows.map(r => {
    if (r.length < colCount) return r.concat(Array(colCount - r.length).fill(""));
    if (r.length > colCount) return r.slice(0, colCount);
    return r;
  });
  const startRow = s.getLastRow() + 1;
  s.getRange(startRow, 1, data.length, colCount).setValues(data);
}

// Build RichTextValue for comments: black daily (line 1), red behavior (line 2)
function buildCommentRichText_(dailyComment, behaviorComment) {
  const d = (dailyComment || "").toString().trim();
  const b = (behaviorComment || "").toString().trim();
  if (!d && !b) return null;
  let text = ""; let ranges = [];
  if (d) { text += d; ranges.push({start:0, end:d.length, color:null}); }
  if (b) { const start = text.length ? (text += "\n", text.length) - 1 : 0; /* will be corrected below */ }
  // Rebuild with exact control
  text = "";
  ranges = [];
  if (d) { text += d; ranges.push({start:0, end:d.length, color:null}); }
  if (b) {
    if (text.length) text += "\n";
    const start = text.length; text += b;
    ranges.push({start, end:start + b.length, color:"#b71c1c"});
  }
  const builder = SpreadsheetApp.newRichTextValue().setText(text);
  ranges.forEach(r => {
    const style = SpreadsheetApp.newTextStyle();
    if (r.color) builder.setTextStyle(r.start, r.end, style.setForegroundColor(r.color).build());
    else builder.setTextStyle(r.start, r.end, style.build());
  });
  return builder.build();
}

// Batch update Comments (matrix) for a date and set of entries
function updateCommentsMatrixForLogs_(sheetName, dateStr, entries) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  syncCommentsMatrixNames_(); // ensure all student columns exist
  const s = ensureCommentsMatrixSheet_(sheetName);
  const dateRow = getOrCreateDateRowIndex_(s, dateStr);
  const lastCol = s.getLastColumn();
  const header = s.getRange(1, 1, 1, lastCol).getValues()[0];
  const nameToCol = new Map();
  for (let j = 2; j <= lastCol; j++) {
    const nm = (header[j - 1] || "").toString();
    if (nm) nameToCol.set(nm, j);
  }
  // Read existing rich text values for the entire row
  const rowRange = s.getRange(dateRow, 1, 1, lastCol);
  let current = [[]];
  try { current = rowRange.getRichTextValues(); } catch (e) {
    // Fallback to plain values if rich text retrieval fails
    const vals = rowRange.getValues()[0];
    current = [vals.map(v => SpreadsheetApp.newRichTextValue().setText((v||'').toString()).build())];
  }
  // Apply updates
  entries.forEach(ent => {
    const col = nameToCol.get(ent.name);
    if (!col) return;
    const rich = buildCommentRichText_(ent.dailyComment, ent.behaviorComment);
    current[0][col - 1] = rich || SpreadsheetApp.newRichTextValue().setText("").build();
  });
  // Ensure date cell contains the dateStr string (display formatting handles date look)
  current[0][0] = SpreadsheetApp.newRichTextValue().setText(dateStr).build();
  rowRange.setRichTextValues(current);
}

