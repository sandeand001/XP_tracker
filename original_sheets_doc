// Revert any edits to Name column on input sheets so it can only change via XP Tracker
function onEdit(e) {
  try {
    if (!e || !e.range) return;
    const sh = e.range.getSheet();
    const name = sh.getName();
    const col = e.range.getColumn();
    const row = e.range.getRow();
    // Protect name mirrors on input sheets
    if (["Daily Checklist", "Behavior Tracker"].includes(name)) {
      if (col === 1 && row >= 2) {
        // Restore the expanding ARRAYFORMULA
        sh.getRange(2, 1).setFormula(`=ARRAYFORMULA(IF(LEN('XP Tracker'!A2:A), 'XP Tracker'!A2:A, ))`);
        try { sh.toast('Name can only be edited on the XP Tracker sheet.', 'Protected', 3); } catch (err) {}
      }
      return;
    }
    // Handle Currency spend input (E column)
    if (name === 'Currency' && col === 5 && row >= 2) {
      const student = (sh.getRange(row, 1).getValue() || '').toString().trim();
      const val = Number(e.value || e.range.getValue() || 0);
      if (!student) return;
      if (!isFinite(val) || val <= 0) return; // ignore invalid/non-positive
  const dateOnly = todayDateOnly_();
  // Validate balance
      const bal = getCoinBalance(student);
      if (bal < val) {
        try {
          sh.toast(`Insufficient coins for ${student}. Balance ${bal}, tried to spend ${val}.`, 'Currency', 4);
        } catch (e) {}
        return;
      }
    appendSpendToXPLog_(dateOnly, student, Math.floor(val), 'Spend via Currency sheet');
      // Clear the entry and refresh row formulas
      try { sh.getRange(row, 5).clearContent(); } catch (e) {}
      try { sh.toast(`Spent ${val} coin(s) for ${student}.`, 'Currency', 3); } catch (e) {}
    }
  } catch (err) {
    // swallow
  }
}

/**** LEVEL/XP/TITLE HELPERS **************************************************/
function getLevelFromXP(xp) {
  for (let i = levelThresholds.length - 1; i >= 0; i--) {
    if (xp >= levelThresholds[i]) return i + 1;
  }
  return 1;
}
function getXPForLevel(level) {
  if (level < 10) return levelThresholds[level] - levelThresholds[level - 1];
  return 0;
}
function determineTitle(cumXP, level) {
  // Prestige lookup: highest milestone not exceeding cumXP
  for (let i = PRESTIGE_TITLES.length - 1; i >= 0; i--) {
    if (cumXP >= PRESTIGE_TITLES[i].xp) return PRESTIGE_TITLES[i].title;
  }
  // Base titles tied to level (pre-prestige)
  switch (level) {
    case 1:  return "Sparkling Novice";
    case 2:  return "Rune Reader";
    case 3:  return "Potion Apprentice";
    case 4:  return "Spell Slinger";
    case 5:  return "Wand Wielder";
    case 6:  return "Magic Adept";
    case 7:  return "Enchanted Knight";
    case 8:  return "Arcane Scholar";
    case 9:  return "Mystic Champion";
    case 10: return "Master Spellcaster";
    default: return "Adventurer";
  }
}

/**** PROCESS *****************************************************************/
function processDailyXP() {
  // One-time setup if needed; avoid re-applying headers/protections on every run
  try { maybeEnsureInit_(); } catch (e) {}

  // Ensure exchange rate is 20 XP/coin
  try { enforceExchangeRate20_(); } catch (e) {}
  const cfg = getRuntimeConfig_();
  const lock = LockService.getDocumentLock();
  try { lock.tryLock(30000); } catch (e) {}
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const daily = ss.getSheetByName("Daily Checklist");
  const tracker = ss.getSheetByName("XP Tracker");
  const behavior = ss.getSheetByName("Behavior Tracker");

  const now = new Date();
  const dateStr = Utilities.formatDate(now, TZ, "yyyy-MM-dd");
  const dateOnly = todayDateOnly_();
  // Precompute prior totals (before today) for carryover coin minting
  const prior = getEarnedAndMintedBeforeDate_(dateStr);

  // Dynamically size based on all relevant sheets (cap at 25 for layout)
  const trackerLastRow = tracker ? tracker.getLastRow() : 1;
  const dailyLastRow   = daily ? daily.getLastRow() : 1;
  const behLastRow     = behavior ? behavior.getLastRow() : 1;
  const N = Math.min(25, Math.max(0, Math.max(trackerLastRow, dailyLastRow, behLastRow) - 1));

  // Prefetch ranges
  const namesTracker = tracker.getRange(2, 1, N, 1).getValues().map(r => (r[0] || "").toString().trim());
  const namesDaily   = daily   ? daily.getRange(2, 1, N, 1).getValues().map(r => (r[0] || "").toString().trim()) : Array(N).fill("");
  const namesBeh     = behavior? behavior.getRange(2, 1, N, 1).getValues().map(r => (r[0] || "").toString().trim()) : Array(N).fill("");
  // Read tracker data needed: C..I (cumXP .. XP Debt)
  const trackerData = tracker.getRange(2, 3, N, 7).getValues(); // C..I
  // Read guild assignments (J) so we can aggregate daily XP per guild
  const guildVals = tracker.getRange(2, 10, N, 1).getValues().map(r => (r[0] || "").toString().trim()); // J
  const dailyVals = daily ? daily.getRange(2, 2, N, 18).getValues() : [];
  const behaviorVals = behavior ? behavior.getRange(2, 2, N, 11).getValues() : [];

  const dailyBonusHeader = daily ? daily.getRange(1, 14, 1, 4).getValues()[0] : [0,0,0,0]; // N1:Q1
  const behaviorExtraHeader = behavior ? behavior.getRange(1, 13, 1, 3).getValues()[0] : [0,0,0]; // M1:O1 (hidden)

  // Prepare output arrays for B..I (we no longer write any currency columns on the tracker)
  const outBJ = Array.from({ length: N }, () => new Array(8).fill(""));
  // Prepare comment updates (only clear when logging)
  const outDailyComments = Array.from({ length: N }, (_, i) => [dailyVals[i] ? (dailyVals[i][17] || "") : ""]);
  const outBehaviorComments = Array.from({ length: N }, (_, i) => [behaviorVals[i] ? (behaviorVals[i][10] || "") : ""]);

  let lastIdx = -1;
  let leaderboardNeedsUpdate = false;
  const xpLogRows = []; // batch rows for XP Log
  const commentEntries = []; // batch entries for Comments (matrix)
  // Accumulate today's earned XP by guild label (used to show guild totals on the leaderboard)
  const guildDailyTotals = Object.create(null);

  // tiny helper once, not per-row allocation
  const t01 = (v) => v === true ? 1 : 0;

  // Track rows (0-based index within processing window) where a student levels up this run
  const levelUpRows = [];

  for (let i = 0; i < N; i++) {
  const name = namesTracker[i] || namesDaily[i] || namesBeh[i] || "";
    if (!name) continue;
    lastIdx = i;

  const earnedXP = Number(dailyVals[i][16]) || 0;          // R
    const dailyComment = (dailyVals[i][17] || "").toString().trim(); // S
    const behaviorDebtDelta = Number(behaviorVals[i][9]) || 0; // K
    const behaviorComment = (behaviorVals[i][10] || "").toString().trim(); // L

  // trackerData columns: C(0)=cumXP, D(1)=level, E(2)=xpInLevel, F(3)=xpToNext, G(4)=sparkline, H(5)=progress, I(6)=debt
  let cumXP = Number(trackerData[i][0]) || 0; // C
  let storedDebt = Number(trackerData[i][6]) || 0; // I

    // Apply debt payment from today's XP
    let totalDebt = storedDebt + behaviorDebtDelta;
    let xpRemaining = earnedXP;
    let debtApplied = 0;
    if (totalDebt < 0 && xpRemaining > 0) {
      const pay = Math.min(xpRemaining, -totalDebt);
      totalDebt += pay;
      xpRemaining -= pay;
      debtApplied = pay;
    }
  const xpTowardLevel = Math.min(xpRemaining, cfg.XP_CAP);
  const xpOverflow = Math.max(0, xpRemaining - cfg.XP_CAP);
  // Carryover rule based on applied XP (XPToLevel only, excludes overflow and debt):
  // coins today = floor((prevApplied + xpTowardLevel)/rate) - prevMinted
  const prev = prior[name] || { applied: 0, minted: 0 };
  const currencyGain = Math.max(0, Math.floor(((Number(prev.applied) || 0) + (Number(xpTowardLevel) || 0)) / cfg.EXCHANGE_RATE) - (Number(prev.minted) || 0));
  cumXP += xpTowardLevel;

  const prevLevel = Number(trackerData[i][1]) || 1; // prior stored level (column D of trackerData)
  const level = getLevelFromXP(cumXP);
  if (level > prevLevel) levelUpRows.push(i); // record level-up (i is 0-based offset; row number = i+2)
    const baseXP = levelThresholds[level - 1];
    const currentLevelXP = cumXP - baseXP;
    const xpToNext = getXPForLevel(level);
    const xpToNextDisplay = xpToNext === 0 ? 0 : Math.max(0, xpToNext - currentLevelXP);
    const percentProgress = xpToNext === 0 ? 1 : (currentLevelXP / xpToNext);
    const title = determineTitle(cumXP, level);

    const rowNum = i + 2;
    outBJ[i][0] = title;                        // B
    outBJ[i][1] = cumXP;                        // C
    outBJ[i][2] = level;                        // D
    outBJ[i][3] = currentLevelXP;               // E
    outBJ[i][4] = xpToNextDisplay;              // F
    outBJ[i][5] = `=SPARKLINE(H${rowNum}, {"charttype","bar";"max",1;"color1","green"})`; // G
    outBJ[i][6] = percentProgress;              // H
  outBJ[i][7] = totalDebt;                    // I

    // Flags for logging (use pre-fetched arrays)
    const testScore = Number(dailyVals[i][0]) || 0; // B
    const fQuiz    = t01(dailyVals[i][1]);
    const fFaculty = t01(dailyVals[i][2]);
    const fExit    = t01(dailyVals[i][3]);
    const fWriting = t01(dailyVals[i][4]);
    const fKindness= t01(dailyVals[i][5]);
    const fExpect  = t01(dailyVals[i][6]);
    const part1 = t01(dailyVals[i][7]);
    const part2 = t01(dailyVals[i][8]);
    const part3 = t01(dailyVals[i][9]);
    const part4 = t01(dailyVals[i][10]);
    const part5 = t01(dailyVals[i][11]);
    const participationCount = part1 + part2 + part3 + part4 + part5;
    const bonusA = t01(dailyVals[i][12]) ? (Number(dailyBonusHeader[0]) || 0) : 0;
    const bonusB = t01(dailyVals[i][13]) ? (Number(dailyBonusHeader[1]) || 0) : 0;
    const bonusC = t01(dailyVals[i][14]) ? (Number(dailyBonusHeader[2]) || 0) : 0;
    const bonusD = t01(dailyVals[i][15]) ? (Number(dailyBonusHeader[3]) || 0) : 0;

    const fMinor = t01(behaviorVals[i][0]);
    const fWarn  = t01(behaviorVals[i][1]);
    const fDisr  = t01(behaviorVals[i][2]);
    const fRept  = t01(behaviorVals[i][3]);
    const fSeri  = t01(behaviorVals[i][4]);
    const fSevr  = t01(behaviorVals[i][5]);
    const extraA = t01(behaviorVals[i][6]) ? -(Number(behaviorExtraHeader[0]) || 0) : 0; // M1
    const extraB = t01(behaviorVals[i][7]) ? -(Number(behaviorExtraHeader[1]) || 0) : 0; // N1
    const extraC = t01(behaviorVals[i][8]) ? -(Number(behaviorExtraHeader[2]) || 0) : 0; // O1

  const shouldLog = (earnedXP > 0) || (behaviorDebtDelta !== 0) || dailyComment || behaviorComment;
  if (shouldLog) {
      xpLogRows.push([
        dateStr, name,
        earnedXP, debtApplied, xpTowardLevel, xpOverflow, currencyGain,
        totalDebt, cumXP, level, title,
        testScore, fQuiz, fFaculty, fExit, fWriting, fKindness, fExpect,
        part1, part2, part3, part4, part5,
        bonusA, bonusB, bonusC, bonusD, participationCount,
        fMinor, fWarn, fDisr, fRept, fSeri, fSevr,
        extraA, extraB, extraC,
        dailyComment, behaviorComment
      ]);
      commentEntries.push({ name, dailyComment, behaviorComment });
      outDailyComments[i][0] = "";
      outBehaviorComments[i][0] = "";
      if (earnedXP > 0 || behaviorDebtDelta !== 0) leaderboardNeedsUpdate = true;
  // Currency is tracked directly via XP Log (CurrencyGain col)
      // Track per-guild daily XP (sum earnedXP for this run). Only count when a guild is assigned.
      try {
        const glabel = guildVals[i] || "";
        if (glabel) {
          guildDailyTotals[glabel] = (guildDailyTotals[glabel] || 0) + (Number(earnedXP) || 0);
        }
      } catch (e) {}
    }
  }

  const rowsToWrite = lastIdx + 1;
  if (rowsToWrite > 0) {
    // Write B..I (8 columns); currency columns are no longer written on the tracker
    tracker.getRange(2, 2, rowsToWrite, 8).setValues(outBJ.slice(0, rowsToWrite)); // B..I

    // Clear any prior level-up highlights in the Name column for the processed rows
    try {
      tracker.getRange(2, 1, rowsToWrite, 1).setBackground(null);
    } catch (e) {}
    // Apply highlight for current run's level-ups (yellow background)
    if (levelUpRows.length) {
      const HIGHLIGHT_COLOR = '#FFF59D'; // soft yellow
      levelUpRows.forEach(idx => {
        try { tracker.getRange(idx + 2, 1).setBackground(HIGHLIGHT_COLOR); } catch (e) {}
      });
    }

    // Reset inputs in bulk
    daily.getRange(2, 2, rowsToWrite, 1).clearContent(); // Test (B)
    try { uncheckSafe_(daily.getRange(2, 3, rowsToWrite, 6)); } catch (e) {}
    try { uncheckSafe_(daily.getRange(2, 9, rowsToWrite, 5)); } catch (e) {}
    try { uncheckSafe_(daily.getRange(2, 14, rowsToWrite, 4)); } catch (e) {}
    try { uncheckSafe_(behavior.getRange(2, 2, rowsToWrite, 6)); } catch (e) {}
    try { uncheckSafe_(behavior.getRange(2, 8, rowsToWrite, 3)); } catch (e) {}

    // Comments: only clear those we logged
    daily.getRange(2, 19, rowsToWrite, 1).setValues(outDailyComments.slice(0, rowsToWrite));
    behavior.getRange(2, 12, rowsToWrite, 1).setValues(outBehaviorComments.slice(0, rowsToWrite));
  }

  if (xpLogRows.length) {
  try { upsertXPLogRowsForDate_(dateStr, xpLogRows); } catch (e) {}
  }
  if (commentEntries.length) {
    try { updateCommentsMatrixForLogs_("Comments (matrix)", dateStr, commentEntries); } catch (e) {}
  }
  // no separate currency ledger to write

  if (leaderboardNeedsUpdate) updateLeaderboard();
  // Nudge Currency summary formulas (reapply current formulas to trigger recalc)
  try {
    const cur = ensureCurrencySheet_();
    for (let row = 2; row <= 26; row++) {
      const fB = cur.getRange(row, 2).getFormula();
      const fC = cur.getRange(row, 3).getFormula();
      const fD = cur.getRange(row, 4).getFormula();
      const fF = cur.getRange(row, 6).getFormula();
      if (fB) cur.getRange(row, 2).setFormula(fB);
      if (fC) cur.getRange(row, 3).setFormula(fC);
      if (fD) cur.getRange(row, 4).setFormula(fD);
      if (fF) cur.getRange(row, 6).setFormula(fF);
    }
  } catch (e) {}
  // Persist today's per-guild totals for the leaderboard to consume when rendering the header summary
  try {
    const props = PropertiesService.getDocumentProperties();
    const keys = Object.keys(guildDailyTotals || {});
    if (keys.length) {
      const payload = { date: dateStr, totals: guildDailyTotals };
      props.setProperty('LATEST_GUILD_DAILY_XP', JSON.stringify(payload));
    } else {
      props.deleteProperty('LATEST_GUILD_DAILY_XP');
    }
  } catch (e) {}
  try { lock.releaseLock(); } catch (e) {}
}

// One-time initializer: fill XP Log CurrencyGain (col G) for rows where it is 0/blank using 1:EXCHANGE_RATE rule on DailyTotalRaw
// backfillCoinsFromXPLog removed — use recomputeCoinsCarryover instead

// Normalize a sheet date cell to yyyy-mm-dd string safely
function normalizeDateStr_(v) {
  if (v instanceof Date) return Utilities.formatDate(v, TZ, 'yyyy-MM-dd');
  const s = (v || '').toString().trim();
  if (!s) return '';
  if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return s;
  const d = new Date(s);
  if (!isNaN(d.getTime())) return Utilities.formatDate(d, TZ, 'yyyy-MM-dd');
  return s;
}

// Build map name -> { applied: sum of XPToLevel (col E) before dateStr, minted: sum of positive CurrencyGain before dateStr }
function getEarnedAndMintedBeforeDate_(dateStr) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const log = ss.getSheetByName('XP Log');
  const out = {};
  if (!log) return out;
  const lastRow = log.getLastRow();
  if (lastRow < 2) return out;
  const n = lastRow - 1;
  const dates = log.getRange(2, 1, n, 1).getValues(); // A
  const names = log.getRange(2, 2, n, 1).getValues(); // B
  const applied = log.getRange(2, 5, n, 1).getValues(); // E XPToLevel
  const coins  = log.getRange(2, 7, n, 1).getValues(); // G
  for (let i = 0; i < n; i++) {
    const d = normalizeDateStr_(dates[i][0]);
    if (!d || d >= dateStr) continue; // strictly before today
    const nm = (names[i][0] || '').toString().trim();
    if (!nm) continue;
    const xp = Number(applied[i][0]) || 0;
    const cg = Number(coins[i][0]) || 0;
    if (!out[nm]) out[nm] = { applied: 0, minted: 0 };
    out[nm].applied += xp;
    if (cg > 0) out[nm].minted += cg;
  }
  return out;
}

// Recompute all positive CurrencyGain values across XP Log using carryover (cumulative XP / rate)
function recomputeCoinsCarryover() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const log = ss.getSheetByName('XP Log');
  if (!log) { try { ss.toast('XP Log not found.', 'Recompute', 3); } catch (e) {} return; }
  try { enforceExchangeRate20_(); } catch (e) {}
  const rate = Math.max(1, Number(getRuntimeConfig_().EXCHANGE_RATE) || 20);
  const lastRow = log.getLastRow();
  if (lastRow < 2) { try { ss.toast('No data to recompute.', 'Recompute', 3); } catch (e) {} return; }
  const n = lastRow - 1;
  const dates = log.getRange(2, 1, n, 1).getValues(); // A
  const names = log.getRange(2, 2, n, 1).getValues(); // B
  const applied = log.getRange(2, 5, n, 1).getValues(); // E XPToLevel
  const coins  = log.getRange(2, 7, n, 1).getValues(); // G
  // Build index array and sort by date ascending, then by original order
  const idx = Array.from({length:n}, (_, i) => i);
  idx.sort((i, j) => {
    const di = normalizeDateStr_(dates[i][0]);
    const dj = normalizeDateStr_(dates[j][0]);
    if (di < dj) return -1; if (di > dj) return 1; return i - j;
  });
  const accumEarned = new Map();
  const mintedSoFar = new Map();
  const newCoins = coins.map(v => [Number(v[0]) || 0]);
  let changes = 0;
  for (const i of idx) {
    const nm = (names[i][0] || '').toString().trim();
    if (!nm) continue;
    const xp = Number(applied[i][0]) || 0;
    const prevEarn = accumEarned.get(nm) || 0;
    const prevMint = mintedSoFar.get(nm) || 0;
    let newMint = 0;
    if (xp > 0) {
      const total = prevEarn + xp;
      newMint = Math.max(0, Math.floor(total / rate) - prevMint);
    } else {
      // No XP: mint stays 0 for this row unless previously set incorrectly (we'll reset to 0 if positive)
      newMint = 0;
    }
    // Preserve spends (negative) exactly
    const old = Number(coins[i][0]) || 0;
    const isSpend = old < 0 || (xp === 0 && old < 0);
    if (isSpend) {
      // Do not alter negative entries, and do not affect mintedSoFar
      newCoins[i][0] = old;
    } else {
      if (old !== newMint) { newCoins[i][0] = newMint; changes++; }
      // Update mintedSoFar by the recomputed positive mint
      if (newMint > 0) mintedSoFar.set(nm, prevMint + newMint);
    }
    // Always advance earned accumulator on XP rows
    if (xp > 0) accumEarned.set(nm, prevEarn + xp);
  }
  if (changes > 0) log.getRange(2, 7, n, 1).setValues(newCoins);
  try {
    const cur = ensureCurrencySheet_();
    for (let row = 2; row <= 26; row++) {
      const fB = cur.getRange(row, 2).getFormula();
      const fC = cur.getRange(row, 3).getFormula();
      const fD = cur.getRange(row, 4).getFormula();
      const fF = cur.getRange(row, 6).getFormula();
      if (fB) cur.getRange(row, 2).setFormula(fB);
      if (fC) cur.getRange(row, 3).setFormula(fC);
      if (fD) cur.getRange(row, 4).setFormula(fD);
      if (fF) cur.getRange(row, 6).setFormula(fF);
    }
  } catch (e) {}
  try { ss.toast(`Recompute complete. Rows changed: ${changes}.`, 'Recompute', 4); } catch (e) {}
}

