    .requireValueInList(list, true)
    .setAllowInvalid(false)
    .build();
    tracker.getRange("J2:J26").setDataValidation(rule)
         .setNote("Select a guild (Guild 1 / Guild 2 / Guild 3).");

  // Replace any existing K-column rules with fresh ones scoped to K2:K26
  const rules = tracker.getConditionalFormatRules();
  const filtered = rules.filter(r => {
    try {
      return !r.getRanges().some(rg => {
        const c = rg.getColumn(), w = rg.getNumColumns();
        const r0 = rg.getRow(), h = rg.getNumRows();
        // Only remove rules that precisely target the Guild picker area (J2:J*)
        return c === 10 && w === 1 && r0 === 2; // e.g., J2:J26
      });
    } catch (e) { return true; }
  });
  const newRules = GUILDS.map(g =>
    SpreadsheetApp.newConditionalFormatRule()
      .whenTextEqualTo(g.label)
      .setBackground(g.bg)
      .setFontColor(g.fg)
      .setRanges([tracker.getRange("J2:J26")])
      .build()
  );
  tracker.setConditionalFormatRules(filtered.concat(newRules));
}

function applyNegativeRedFormatting_(sheet, a1Range) {
  const range = sheet.getRange(a1Range);
  const rules = sheet.getConditionalFormatRules() || [];
  // Remove any existing rules that target this range (to avoid duplicates)
  const filtered = rules.filter(r => {
    try {
      return !r.getRanges().some(rg => rg.getA1Notation() === a1Range);
    } catch (e) { return true; }
  });
  const rule = SpreadsheetApp.newConditionalFormatRule()
    .whenNumberLessThan(0)
    .setFontColor("#b71c1c")
    .setRanges([range])
    .build();
  sheet.setConditionalFormatRules(filtered.concat([rule]));
}

